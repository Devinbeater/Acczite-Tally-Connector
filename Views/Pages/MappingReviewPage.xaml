<Page x:Class="Acczite20.Views.Pages.MappingReviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Cross-Platform Mapping Review"
      Background="{DynamicResource SystemControlPageBackgroundListLowBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Entity Mapping Review" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <TextBlock Text="Review and confirm suggested links between MERN cloud entities and Tally records." 
                       FontSize="14" 
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Refresh List" 
                    Click="Refresh_Click"
                    Margin="0,0,8,0"/>
            <ComboBox x:Name="EntityTypeFilter" 
                      Width="180" 
                      ui:ControlHelper.PlaceholderText="Filter by Type"
                      SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="All Types"/>
                <ComboBoxItem Content="Product"/>
                <ComboBoxItem Content="Employee"/>
                <ComboBoxItem Content="Godown"/>
            </ComboBox>
        </StackPanel>

        <!-- Mapping List -->
        <ui:ListView x:Name="MappingList" Grid.Row="2">
            <ui:ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Entity Icon -->
                        <ui:SymbolIcon Symbol="Contact" 
                                      Width="24" Height="24"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Grid.Column="0"/>

                        <!-- MERN Side -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MernDisplayName}" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="{Binding EntityType}" FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="{Binding MernId, StringFormat='MERN ID: {0}'}" FontSize="10" Opacity="0.5"/>
                        </StackPanel>

                        <!-- Arrow -->
                        <ui:SymbolIcon Symbol="Forward" 
                                      Grid.Column="2" 
                                      VerticalAlignment="Center" 
                                      Opacity="0.5"/>

                        <!-- Suggested Tally Match -->
                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SuggestedTallyName}" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                            <TextBlock Text="Tally Suggested Match" FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="{Binding ConfidenceScore, StringFormat='Confidence: {0:P0}'}" FontSize="11" Foreground="#4CAF50"/>
                        </StackPanel>

                        <!-- Status Badge -->
                        <Border Grid.Column="4" 
                                Padding="8,4" 
                                CornerRadius="4" 
                                Background="#FFF9C4" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Status}" Foreground="#FBC02D" FontWeight="Bold" FontSize="11"/>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                            <Button Content="Approve" 
                                    Background="#E8F5E9"
                                    Foreground="#2E7D32"
                                    BorderBrush="#A5D6A7"
                                    Click="Approve_Click"
                                    Tag="{Binding Id}"
                                    Width="100"
                                    Margin="0,0,8,0"/>
                            <Button Content="Reject" 
                                    Background="#FFEBEE"
                                    Foreground="#C62828"
                                    BorderBrush="#FFCDD2"
                                    Click="Reject_Click"
                                    Tag="{Binding Id}"
                                    Width="100"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
        </ui:ListView>

        <!-- Empty State -->
        <StackPanel x:Name="EmptyState" 
                    Grid.Row="2" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <ui:SymbolIcon Symbol="Accept" Width="64" Height="64" Opacity="0.2"/>
            <TextBlock Text="No pending mappings found." 
                       FontSize="18" 
                       Opacity="0.5" 
                       Margin="0,16,0,0"/>
            <TextBlock Text="All cloud entities have been successfully linked to Tally records." 
                       FontSize="14" 
                       Opacity="0.3"/>
        </StackPanel>
    </Grid>
</Page>
