<Page x:Class="Acczite20.Views.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Acczite20.ViewModels"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="RegisterPage">
    <Page.DataContext>
        <vm:RegisterViewModel />
    </Page.DataContext>

    <Grid Background="{StaticResource LightTealBg}">
        <Border Background="White" CornerRadius="16" MaxWidth="450" VerticalAlignment="Center" Margin="20" Padding="40" Effect="{StaticResource CardShadow}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Create Account" FontSize="28" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                    <TextBlock Text="Join Acczite for seamless Tally cloud synchronization" FontSize="13" Foreground="#6B7280" Margin="0,5,0,30"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Margin="0,0,10,20">
                            <TextBlock Text="Username" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,20">
                            <TextBlock Text="Email Address" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center" ui:ControlHelper.PlaceholderText="your@email.com"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Password" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                        <PasswordBox PasswordChanged="PasswordBox_PasswordChanged" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Confirm Password" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                        <PasswordBox PasswordChanged="ConfirmPasswordBox_PasswordChanged" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <Button Content="Create Account" Style="{StaticResource PrimaryButtonStyle}" Height="45" FontSize="15" FontWeight="Bold" Click="RegisterButton_Click"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                        <TextBlock Text="Already have an account?" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>
                        <Button Content="Login" Click="LoginButton_Click" Background="Transparent" BorderThickness="0" Foreground="{StaticResource PrimaryTeal}" FontWeight="Bold" FontSize="13" Margin="8,0,0,0" Padding="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
