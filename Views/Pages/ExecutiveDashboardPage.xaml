<Page x:Class="Acczite20.Views.Pages.ExecutiveDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Business Pulse"
      Background="{StaticResource LightTealBg}">

    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 1. Header & Quick Actions -->
            <DockPanel Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="Daily Business Pulse" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                    <TextBlock x:Name="TxtClock" Text="Wednesday, 11 March 2026 • 04:50 PM" Foreground="{StaticResource GrayText}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="📥 Download PDF" Click="Download_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="Refresh" Click="Refresh_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </DockPanel>

            <!-- 2. The Big Pulse Numbers (KPI Row) -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">
                <!-- Sales Today -->
                <Border Background="{StaticResource BaseWhite}" CornerRadius="15" Padding="20" Margin="0,0,15,0" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Sales Today" Foreground="#6B7280" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtSalesToday" Text="₹ 0.00" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,5"/>
                        <TextBlock x:Name="TxtInvoicesToday" Text="0 Invoices" Foreground="#10B981" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Collections Today -->
                <Border Background="{StaticResource BaseWhite}" CornerRadius="15" Padding="20" Margin="0,0,15,0" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Collections Today" Foreground="#6B7280" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtCollectionsToday" Text="₹ 0.00" FontSize="32" FontWeight="Bold" Foreground="#0D9488" Margin="0,5"/>
                        <TextBlock Text="Bank &amp; Cash Receipts" Foreground="#6B7280"/>
                    </StackPanel>
                </Border>

                <!-- Net Cash/Bank -->
                <Border Background="{StaticResource BaseWhite}" CornerRadius="15" Padding="20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Cash Position" Foreground="#6B7280" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtCashPosition" Text="₹ 0.00" FontSize="32" FontWeight="Bold" Foreground="#1F2937" Margin="0,5"/>
                        <TextBlock Text="Available Liquidity" Foreground="#6B7280"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 3. Receivables & Payables (Exposure) -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F0F9FF" CornerRadius="15" Padding="20" Margin="0,0,10,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Receivables (Clients Owe You)" FontWeight="SemiBold" Foreground="#0369A1"/>
                        <TextBlock x:Name="TxtReceivables" Text="₹ 0.00" FontSize="28" FontWeight="Bold" Foreground="#0C4A6E" VerticalAlignment="Center" Margin="0,10"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFF1F2" CornerRadius="15" Padding="20" Margin="10,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Payables (You Owe Suppliers)" FontWeight="SemiBold" Foreground="#BE123C"/>
                        <TextBlock x:Name="TxtPayables" Text="₹ 0.00" FontSize="28" FontWeight="Bold" Foreground="#881337" VerticalAlignment="Center" Margin="0,10"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 4. Attention Needed (Alerts) -->
            <Border Grid.Row="3" Background="{StaticResource BaseWhite}" CornerRadius="15" Padding="25" Effect="{StaticResource CardShadow}">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Top" Text="Smart Insights &amp; Alerts" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource CharcoalText}"/>

                    <Grid x:Name="EmptyAlertsPlaceholder" DockPanel.Dock="Top" Height="100" Visibility="Collapsed">
                        <TextBlock Text="Everything looks good! No critical alerts at the moment." 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Foreground="{StaticResource GrayText}" FontStyle="Italic"/>
                    </Grid>

                    <ItemsControl x:Name="AlertsList" DockPanel.Dock="Top">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="0,12">
                                    <DockPanel>
                                        <Border Width="12" Height="12" CornerRadius="6" VerticalAlignment="Center" Margin="0,0,15,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F59E0B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                            <Setter Property="Background" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Category}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource GrayText}"/>
                                            <TextBlock Text="{Binding Message}" FontSize="16" Foreground="{StaticResource CharcoalText}"/>
                                        </StackPanel>
                                        <Button DockPanel.Dock="Right" Content="Details" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="12,4" FontSize="12"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button DockPanel.Dock="Bottom" 
                            Content="View Full Activity Timeline →" 
                            Style="{StaticResource PrimaryButtonStyle}" 
                            HorizontalAlignment="Center" 
                            Click="ViewTimeline_Click"
                            Margin="0,20,0,0"
                            Padding="20,8"/>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
