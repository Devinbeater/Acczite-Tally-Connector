<Page x:Class="Acczite20.Views.Pages.LedgerExplorerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Ledger Explorer" Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Controls -->
        <Border Grid.Row="0" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Search Ledgers" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8"/>
                    <TextBox x:Name="SearchBox" ui:ControlHelper.PlaceholderText="Ledger Name or Group..." Height="36" Width="300" HorizontalAlignment="Left" TextChanged="SearchBox_TextChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- List and Detail View Split -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- List Panel -->
            <Border Grid.Column="0" Background="{StaticResource BaseWhite}" CornerRadius="8" Margin="0,0,16,0" Effect="{StaticResource CardShadow}" ClipToBounds="True">
                <DockPanel>
                    <!-- Pagination Bar -->
                    <Border DockPanel.Dock="Bottom" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="12,8">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Showing page " Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" VerticalAlignment="Center"/>
                                <TextBlock Text=" of " Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalPages}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" VerticalAlignment="Center"/>
                                <TextBlock Text=" (" Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalRecords}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" VerticalAlignment="Center"/>
                                <TextBlock Text=" ledgers)" Foreground="#64748B" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                        ToolTip="Previous Page" Background="Transparent" BorderThickness="0"
                                        Width="32" Height="32" Click="PrevPage_Click" 
                                        IsEnabled="{Binding CanGoBack}"/>
                                <Button Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                        ToolTip="Next Page" Background="Transparent" BorderThickness="0"
                                        Width="32" Height="32" Margin="4,0,0,0" Click="NextPage_Click"
                                        IsEnabled="{Binding CanGoForward}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Data Grid -->
                    <DataGrid x:Name="LedgersGrid" 
                              ItemsSource="{Binding Ledgers}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="LedgersGrid_SelectionChanged"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E5E7EB"
                              BorderThickness="0"
                              Background="Transparent"
                              RowHeight="40">
                              
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E0F2F1"/>
                                        <Setter Property="Foreground" Value="{StaticResource CharcoalText}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ledger Name" Binding="{Binding Name}" Width="1.5*"/>
                            <DataGridTextColumn Header="Parent Group" Binding="{Binding ParentGroup}" Width="1.2*"/>
                            <DataGridTextColumn Header="Opening Bal" Binding="{Binding OpeningBalance, StringFormat={}{0:N2}}" Width="1*"/>
                            <DataGridTextColumn Header="Closing Bal" Binding="{Binding ClosingBalance, StringFormat={}{0:N2}}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Effect="{StaticResource CardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Visibility="Hidden">
                        <!-- Header -->
                        <TextBlock Text="{Binding SelectedLedger.Name}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Group:" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedLedger.ParentGroup}" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Opening:" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedLedger.OpeningBalance, StringFormat={}{0:N2}}" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Closing:" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedLedger.ClosingBalance, StringFormat={}{0:N2}}" Foreground="{StaticResource CharcoalText}"/>
                        </Grid>

                        <!-- Transaction Entries -->
                        <TextBlock Text="Recent Transactions" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8"/>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding SelectedLedger.Entries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Date, StringFormat={}{0:dd MMM yyyy}}" Foreground="#6B7280" FontSize="11"/>
                                                    <TextBlock Text="{Binding VoucherNumber}" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                
                                                <!-- Debit -->
                                                <TextBlock Grid.Column="1" Text="{Binding Debit, StringFormat={}{0:N2}}" 
                                                           Foreground="#22C55E" Margin="16,0,0,0" Width="70" TextAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Debit}" Value="0">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Text="DR" Foreground="#22C55E" FontSize="9" Margin="86,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Debit}" Value="0">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Credit -->
                                                <TextBlock Grid.Column="2" Text="{Binding Credit, StringFormat={}{0:N2}}" 
                                                           Foreground="#EF4444" Margin="16,0,0,0" Width="70" TextAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Credit}" Value="0">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" Text="CR" Foreground="#EF4444" FontSize="9" Margin="86,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Credit}" Value="0">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
