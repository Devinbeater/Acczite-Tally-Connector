<Page x:Class="Acczite20.Views.Pages.ProfitAndLossPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Profit &amp; Loss Account"
      Background="{StaticResource LightTealBg}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Profit &amp; Loss Account" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <DatePicker x:Name="FromDatePicker" Width="120" Margin="0,0,10,0"/>
                <DatePicker x:Name="ToDatePicker" Width="120" Margin="0,0,10,0"/>
                <Button Content="Refresh" Click="Refresh_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </DockPanel>

        <!-- P&L Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Expenditures (Left) -->
            <Border Grid.Column="0" Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="20" Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Expenditures" FontSize="18" FontWeight="SemiBold" Foreground="#EF4444" Margin="0,0,0,15"/>
                    
                    <Grid DockPanel.Dock="Bottom" Margin="0,15,0,0">
                        <TextBlock Text="Total Expenditure" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="TxtTotalExpense" Text="₹ 0.00" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16"/>
                    </Grid>

                    <ScrollViewer>
                        <ItemsControl x:Name="ExpenseList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding GroupName}" Margin="0,0,0,5" FontWeight="Medium">
                                        <ItemsControl ItemsSource="{Binding Ledgers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="20,5,10,5">
                                                        <TextBlock Text="{Binding LedgerName}" Foreground="{StaticResource CharcoalText}"/>
                                                        <TextBlock Text="{Binding Amount, StringFormat=N2}" HorizontalAlignment="Right" Foreground="{StaticResource CharcoalText}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Incomes (Right) -->
            <Border Grid.Column="1" Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="20" Margin="10,0,0,0" Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Incomes" FontSize="18" FontWeight="SemiBold" Foreground="#10B981" Margin="0,0,0,15"/>

                    <Grid DockPanel.Dock="Bottom" Margin="0,15,0,0">
                        <TextBlock Text="Total Income" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="TxtTotalIncome" Text="₹ 0.00" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16"/>
                    </Grid>

                    <ScrollViewer>
                        <ItemsControl x:Name="IncomeList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding GroupName}" Margin="0,0,0,5" FontWeight="Medium">
                                        <ItemsControl ItemsSource="{Binding Ledgers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="20,5,10,5">
                                                        <TextBlock Text="{Binding LedgerName}" Foreground="{StaticResource CharcoalText}"/>
                                                        <TextBlock Text="{Binding Amount, StringFormat=N2}" HorizontalAlignment="Right" Foreground="{StaticResource CharcoalText}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Net Profit/Loss Overlay (Bottom Center) -->
            <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                    Background="{StaticResource PrimaryTeal}" CornerRadius="20" Padding="30,10" Margin="0,0,0,20" Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TxtPlLabel" Text="Net Profit:" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtNetPl" Text="₹ 0.00" Foreground="White" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
