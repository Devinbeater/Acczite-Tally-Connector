<Page x:Class="Acczite20.Views.Pages.TableSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Table Selection"
      Loaded="TableSelectionPage_Loaded">

	<Grid Margin="30" Background="#F8F8FF">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<TextBlock Grid.Row="0"
                   Text="🗂 Select Tables to Sync"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#4B0082"
                   Margin="0,0,0,20"
                   HorizontalAlignment="Left"/>

		<!-- Table DataGrid -->
		<Border Grid.Row="1" BorderBrush="#D3D3D3" BorderThickness="1" CornerRadius="8" Background="White" Padding="5">
			<DataGrid x:Name="TableDataGrid"
                      ItemsSource="{Binding AvailableTables}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Vertical"
                      SelectionMode="Extended"
                      IsReadOnly="False"
                      ColumnHeaderHeight="30"
                      RowHeight="30"
                      FontSize="14"
                      AlternatingRowBackground="#F5F5F5"
                      BorderThickness="0">
				<DataGrid.Columns>
					<!-- Checkbox for Selection -->
					<DataGridCheckBoxColumn Header="Select"
                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="80" />

					<!-- Table Name -->
					<DataGridTextColumn Header="Table Name"
                                        Binding="{Binding Name}"
                                        IsReadOnly="True"
                                        Width="*" />

					<!-- Sequence Number -->
					<DataGridTextColumn Header="Sequence #"
                                        Binding="{Binding SequenceNumber}"
                                        IsReadOnly="True"
                                        Width="100" />

					<!-- Tally Field -->
					<DataGridTextColumn Header="Tally Field"
                                        Binding="{Binding MatchedField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="150" />
				</DataGrid.Columns>
			</DataGrid>
		</Border>

		<!-- Action Buttons -->
		<StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,25,0,0">
			<Button Content="⮜ Back"
                    Width="100"
                    Height="35"
                    Click="Back_Click"
                    Background="#DCDCDC"
                    Foreground="Black"
                    FontWeight="SemiBold"
                    BorderBrush="#A9A9A9"
                    BorderThickness="1"
                    Padding="5"
                    Margin="0,0,10,0"
                    Cursor="Hand" />

			<Button Content="Next ⮞"
                    Width="100"
                    Height="35"
                    Click="Next_Click"
                    Background="#4B0082"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderBrush="#4B0082"
                    BorderThickness="1"
                    Padding="5"
                    Cursor="Hand" />
		</StackPanel>
	</Grid>
</Page>
