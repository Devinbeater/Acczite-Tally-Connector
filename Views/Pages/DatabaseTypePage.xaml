<Page x:Class="AccziteCleanV1.Views.Pages.DatabaseTypePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:AccziteCleanV1.Views.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Database Type">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select Database Type" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" >
            <RadioButton Content="SQL Server" IsChecked="{Binding IsSqlServerSelected}" Margin="0,0,0,10"/>
            <RadioButton Content="PostgreSQL" IsChecked="{Binding IsPostgreSqlSelected}" Margin="0,0,0,10"/>
            <RadioButton Content="SQLite" IsChecked="{Binding IsSqliteSelected}" Margin="0,0,0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Back" Command="{Binding BackCommand}" Margin="0,0,10,0"/>
            <Button Content="Next" Command="{Binding NextCommand}"/>
        </StackPanel>
    </Grid>
</Page>