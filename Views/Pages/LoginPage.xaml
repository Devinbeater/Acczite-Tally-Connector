<Page x:Class="Acczite20.Views.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Acczite20.ViewModels"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="LoginPage">

    <Page.DataContext>
        <vm:LoginViewModel />
    </Page.DataContext>

    <Grid Background="{StaticResource LightTealBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Brand Panel -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryTeal}">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">
                    <TextBlock Text="Acczite 2.0" FontSize="56" FontWeight="Black" Foreground="White"/>
                    <TextBlock Text="Unified Business Accounting" FontSize="18" Foreground="White" Opacity="0.8" Margin="0,10,0,0"/>
                    <Border Height="4" Width="60" Background="{StaticResource GoldMetallic}" HorizontalAlignment="Left" Margin="2,30,0,0" CornerRadius="2"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,60,0,0">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource GoldMetallic}" VerticalAlignment="Center"/>
                        <TextBlock Text="Secure Cloud Backend" FontSize="14" Foreground="White" Opacity="0.9" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource GoldMetallic}" VerticalAlignment="Center"/>
                        <TextBlock Text="Real-time Tally Integration" FontSize="14" Foreground="White" Opacity="0.9" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="© 2026 Acczite Solutions" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="40" Foreground="White" Opacity="0.4" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Form Panel -->
        <Border Grid.Column="1">
            <Border Background="White" CornerRadius="16" MaxWidth="380" VerticalAlignment="Center" Margin="40" Padding="40" Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Sign In" FontSize="28" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                    <TextBlock Text="Enter your credentials to manage your sync" FontSize="13" Foreground="#6B7280" Margin="0,5,0,30"/>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Email or Username" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="EmailTextBox" Text="{Binding LoginId, UpdateSourceTrigger=PropertyChanged}" Height="42" VerticalContentAlignment="Center" ui:ControlHelper.PlaceholderText="Enter login ID" TextChanged="EmailTextBox_TextChanged"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Password" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="PasswordBox" Height="42" VerticalContentAlignment="Center" PasswordChanged="PasswordBox_PasswordChanged"/>
                    </StackPanel>

                    <Button Content="Login" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="45" FontSize="15" FontWeight="Bold"/>

                    <Grid Margin="0,30,0,0">
                        <Separator VerticalAlignment="Center"/>
                        <TextBlock Text="OR" Background="White" HorizontalAlignment="Center" Padding="15,0" FontSize="12" Foreground="#9CA3AF"/>
                    </Grid>

                    <Button x:Name="RegisterButton" Content="Create New Account" Click="RegisterButton_Click" Background="Transparent" BorderThickness="0" Foreground="{StaticResource PrimaryTeal}" FontWeight="Bold" Margin="0,20,0,0" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
