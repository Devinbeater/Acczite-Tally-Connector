<Page x:Class="Acczite20.Views.Pages.LedgerDrillDownPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ledger Drill-Down" Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Opening balance bar -->
            <RowDefinition Height="*"/>      <!-- DataGrid -->
            <RowDefinition Height="Auto"/>   <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource BaseWhite}" CornerRadius="8"
                Padding="20,16" Margin="0,0,0,12" Effect="{StaticResource CardShadow}">
            <DockPanel>
                <Button x:Name="BtnBack" DockPanel.Dock="Left" Content="← Back"
                        Click="BtnBack_Click"
                        Background="Transparent" BorderThickness="0"
                        FontSize="14" Foreground="{StaticResource PrimaryTeal}"
                        Cursor="Hand" Margin="0,0,16,0"/>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="TxtLedgerName" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTeal}"/>
                    <TextBlock x:Name="TxtPeriod" Foreground="{StaticResource CharcoalText}" Opacity="0.7" FontSize="12"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="6" Padding="16,8" Margin="0,0,12,0"
                            Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Opening Balance" FontSize="11" FontWeight="Bold"
                                       Foreground="#166534" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="TxtOpeningBalance" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#15803D" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="6" Padding="16,8"
                            Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Total Entries" FontSize="11" FontWeight="Bold"
                                       Foreground="#374151" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="TxtTotalEntries" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#111827" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Running opening balance for current page ───────────────────── -->
        <Border x:Name="PageOpeningBar" Grid.Row="1" Background="#FFFBEB"
                BorderBrush="#FDE68A" BorderThickness="1"
                CornerRadius="6" Padding="16,8" Margin="0,0,0,8"
                Visibility="Collapsed">
            <TextBlock x:Name="TxtPageOpening" FontSize="12" Foreground="#92400E"/>
        </Border>

        <!-- ── DataGrid ────────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource BaseWhite}"
                CornerRadius="8" Effect="{StaticResource CardShadow}" ClipToBounds="True">
            <DataGrid x:Name="EntriesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E5E7EB"
                      BorderThickness="0"
                      Background="Transparent"
                      RowHeight="34"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="Foreground" Value="#374151"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <!-- Row color: negative running balance = light red background -->
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNegativeBalance}" Value="True">
                                <Setter Property="Background" Value="#FFF5F5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Date -->
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding Date, StringFormat=dd-MMM-yy}"
                                        Width="95" SortMemberPath="Date">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Foreground" Value="#374151"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Voucher Number -->
                    <DataGridTextColumn Header="Voucher No"
                                        Binding="{Binding VoucherNumber}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Voucher Type -->
                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding VoucherType}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Narration (fills remaining space) -->
                    <DataGridTextColumn Header="Narration"
                                        Binding="{Binding Narration}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Debit (green) -->
                    <DataGridTextColumn Header="Debit"
                                        Binding="{Binding DebitDisplay}"
                                        Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#15803D"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Credit (red) -->
                    <DataGridTextColumn Header="Credit"
                                        Binding="{Binding CreditDisplay}"
                                        Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#B91C1C"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Running Balance (color by sign) -->
                    <DataGridTemplateColumn Header="Balance" Width="130" SortMemberPath="RunningBalance">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding BalanceDisplay}"
                                           TextAlignment="Right"
                                           FontSize="13" FontWeight="Bold"
                                           Margin="12,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#15803D"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNegativeBalance}" Value="True">
                                                    <Setter Property="Foreground" Value="#B91C1C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Pagination bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="3" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock x:Name="TxtEntryRange"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#6B7280" FontSize="12"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnPrev" Content="← Previous"
                            Click="BtnPrev_Click"
                            Padding="12,6" Margin="0,0,8,0"
                            Background="#F3F4F6" BorderThickness="0"
                            Foreground="#374151" Cursor="Hand"/>
                    <Border Background="#F3F4F6" CornerRadius="4" Padding="12,6">
                        <TextBlock x:Name="TxtPageInfo" FontSize="12" Foreground="#374151"/>
                    </Border>
                    <Button x:Name="BtnNext" Content="Next →"
                            Click="BtnNext_Click"
                            Padding="12,6" Margin="8,0,0,0"
                            Background="{StaticResource PrimaryTeal}" BorderThickness="0"
                            Foreground="White" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Page>
