<Page x:Class="Acczite20.Views.Pages.VoucherExplorerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Voucher Explorer" Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Controls -->
        <Border Grid.Row="0" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Search Vouchers" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8"/>
                    <TextBox x:Name="SearchBox" ui:ControlHelper.PlaceholderText="Voucher No. or Narration..." Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="From Date" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8"/>
                    <DatePicker x:Name="FromDatePicker" Height="36" Width="Auto"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                    <TextBlock Text="To Date" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8"/>
                    <DatePicker x:Name="ToDatePicker" Height="36" Width="Auto"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Search" Style="{StaticResource PrimaryButtonStyle}" 
                        Height="36" Width="100" VerticalAlignment="Bottom" Click="Search_Click"/>
            </Grid>
        </Border>

        <!-- Voucher List and Detail View Split -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- List Panel -->
            <Border Grid.Column="0" Background="{StaticResource BaseWhite}" CornerRadius="8" Margin="0,0,16,0" Effect="{StaticResource CardShadow}" ClipToBounds="True">
                <DockPanel>
                    <!-- Pagination Bar -->
                    <Border DockPanel.Dock="Bottom" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="12,8">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Showing page " Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" VerticalAlignment="Center"/>
                                <TextBlock Text=" of " Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalPages}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" VerticalAlignment="Center"/>
                                <TextBlock Text=" (" Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalRecords}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" VerticalAlignment="Center"/>
                                <TextBlock Text=" vouchers)" Foreground="#64748B" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                        ToolTip="Previous Page" Background="Transparent" BorderThickness="0"
                                        Width="32" Height="32" Click="PrevPage_Click" 
                                        IsEnabled="{Binding CanGoBack}"/>
                                <Button Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                        ToolTip="Next Page" Background="Transparent" BorderThickness="0"
                                        Width="32" Height="32" Margin="4,0,0,0" Click="NextPage_Click"
                                        IsEnabled="{Binding CanGoForward}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Data Grid -->
                    <DataGrid x:Name="VouchersGrid" 
                              ItemsSource="{Binding Vouchers}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="VouchersGrid_SelectionChanged"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E5E7EB"
                              BorderThickness="0"
                              Background="Transparent"
                              RowHeight="40">
                              
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E0F2F1"/>
                                        <Setter Property="Foreground" Value="{StaticResource CharcoalText}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Voucher No" Binding="{Binding VoucherNumber}" Width="1.5*"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:dd MMM yyyy}}" Width="1.2*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="1.5*"/>
                            <DataGridTextColumn Header="Narration" Binding="{Binding Narration}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Effect="{StaticResource CardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Visibility="Hidden">
                        <!-- Header -->
                        <TextBlock Text="Voucher Details" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Voucher No:" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedVoucher.VoucherNumber}" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Date:" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedVoucher.Date, StringFormat={}{0:dd MMM yyyy}}" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Narration:" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedVoucher.Narration}" TextWrapping="Wrap" Foreground="{StaticResource CharcoalText}"/>
                        </Grid>

                        <!-- Ledger Entries -->
                        <TextBlock Text="Ledger Entries" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8"/>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding SelectedVoucher.LedgerEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding LedgerName}" Foreground="{StaticResource CharcoalText}"/>
                                            
                                            <!-- Debit -->
                                            <TextBlock Grid.Column="1" Text="{Binding DebitAmount, StringFormat={}{0:N2}}" 
                                                       Foreground="#22C55E" Margin="16,0,0,0" Width="80" TextAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DebitAmount}" Value="0">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="DR" Foreground="#22C55E" FontSize="10" Margin="96,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DebitAmount}" Value="0">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Credit -->
                                            <TextBlock Grid.Column="2" Text="{Binding CreditAmount, StringFormat={}{0:N2}}" 
                                                       Foreground="#EF4444" Margin="16,0,0,0" Width="80" TextAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CreditAmount}" Value="0">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" Text="CR" Foreground="#EF4444" FontSize="10" Margin="96,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CreditAmount}" Value="0">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Inventory -->
                        <TextBlock Text="Inventory" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedVoucher.Inventory.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedVoucher.Inventory.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ItemsControl ItemsSource="{Binding SelectedVoucher.Inventory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding StockItemName}" Foreground="{StaticResource CharcoalText}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="Qty:" Foreground="#6B7280" Margin="16,0,4,0"/>
                                                <TextBlock Text="{Binding ActualQuantity}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                                <TextBlock Text=" Rate:" Foreground="#6B7280" Margin="12,0,4,0"/>
                                                <TextBlock Text="{Binding Rate, StringFormat={}{0:N2}}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- GST -->
                        <TextBlock Text="GST Breakdown" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedVoucher.Gst.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedVoucher.Gst.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ItemsControl ItemsSource="{Binding SelectedVoucher.Gst}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TaxType}" Foreground="{StaticResource CharcoalText}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TaxRate, StringFormat={}{0:N2}%}" Foreground="#6B7280" Margin="16,0,0,0" Width="50" TextAlignment="Right"/>
                                            <TextBlock Grid.Column="2" Text="{Binding AssessableValue, StringFormat={}{0:N2}}" Foreground="#6B7280" Margin="16,0,0,0" Width="80" TextAlignment="Right"/>
                                            <TextBlock Grid.Column="3" Text="{Binding TaxAmount, StringFormat={}{0:N2}}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="16,0,0,0" Width="80" TextAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Total -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                            <Grid>
                                <TextBlock Text="Total Amount:" FontSize="16" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                                <TextBlock Text="{Binding SelectedVoucher.TotalAmount, StringFormat={}{0:N2}}" 
                                           FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
