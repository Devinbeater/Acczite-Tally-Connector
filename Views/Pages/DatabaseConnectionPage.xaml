<Page x:Class="Acczite20.Views.Pages.DatabaseConnectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d"
      Title="Database Connection Configuration"
      Background="{StaticResource LightTealBg}"
      ui:ThemeManager.RequestedTheme="Light">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="← Back" Click="Back_Click" 
                Style="{StaticResource SidebarButtonStyle}" Foreground="{StaticResource PrimaryTeal}" 
                HorizontalAlignment="Left" Height="32" Margin="0,0,0,6" FontSize="13"/>

        <TextBlock Grid.Row="1" Text="Database Configuration" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="2" Text="Provide connection logic for SQL/NoSQL databases to store synchronized records." FontSize="14" Foreground="{StaticResource CharcoalText}" Opacity="0.7" Margin="0,0,0,25"/>

        <Border Grid.Row="3" Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="24" 
                BorderBrush="#E5E7EB" BorderThickness="1"
                Effect="{StaticResource CardShadow}"
                VerticalAlignment="Top" HorizontalAlignment="Left" Width="550">
            <StackPanel>
                <TextBlock Text="Database Type" Margin="0,0,0,5" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold"/>
                <ComboBox x:Name="DbTypeComboBox" Width="230" HorizontalAlignment="Left" SelectedIndex="0" Margin="0,0,0,20" SelectionChanged="DbTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="MySQL"/>
                    <ComboBoxItem Content="PostgreSQL"/>
                    <ComboBoxItem Content="SQL Server"/>
                    <ComboBoxItem Content="MongoDB"/>
                </ComboBox>

                <Grid x:Name="SqlPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="Server / Host" Margin="0,0,0,5" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold"/>
                        <TextBox x:Name="ServerBox" Width="230" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                        <TextBlock Text="Database Name" Margin="0,0,0,5" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold"/>
                        <TextBox x:Name="DatabaseBox" Width="230" HorizontalAlignment="Left" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Port Number" Margin="0,0,0,5" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold"/>
                        <TextBox x:Name="PortBox" Width="230" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                        <TextBlock Text="Username" Margin="0,0,0,5" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold"/>
                        <TextBox x:Name="UsernameBox" Width="230" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                        <TextBlock Text="Password" Margin="0,0,0,5" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold"/>
                        <PasswordBox x:Name="PasswordBox" Width="230" HorizontalAlignment="Left" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="MongoPanel" Visibility="Collapsed" Margin="0,0,0,20">
                    <TextBlock Text="Connection URI" Margin="0,0,0,5" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold"/>
                    <TextBox x:Name="MongoUriBox" Width="480" HorizontalAlignment="Left" Margin="0,0,0,5" />
                    <TextBlock Text="e.g. mongodb://user:pass@localhost:27017/acczite" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
                </StackPanel>

                <!-- Dynamic Data List (Collections/Tables) -->
                <StackPanel x:Name="CollectionsPanel" Visibility="Collapsed" Margin="0,0,0,20">
                    <TextBlock x:Name="CollectionsHeader" Text="Available Collections" FontWeight="Bold" FontSize="15" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,10"/>
                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Height="120" Width="480" HorizontalAlignment="Left">
                        <ListBox x:Name="CollectionsListBox" Background="Transparent" BorderThickness="0" Margin="5"/>
                    </Border>
                    <TextBlock Text="Select the datasets involved in the sync routine." FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- Actions -->
                <Separator Margin="0,10,0,20" Background="#E5E7EB"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Test Connection" 
                            Click="TestConnection_Click" 
                            Style="{StaticResource SidebarButtonStyle}" 
                            Foreground="{StaticResource PrimaryTeal}" 
                            Margin="0,0,15,0"/>
                            
                    <Button Content="Save &amp; Continue" 
                            Click="Next_Click" 
                            Style="{StaticResource PrimaryButtonStyle}" 
                            Width="160"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
