<Page x:Class="Acczite20.Views.Pages.TallyExecutePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="TallyExecutePage"
      Background="{StaticResource LightTealBg}">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,40">
            <TextBlock Text="Ready for Enterprise Sync" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
            <TextBlock Text="Review the configuration summary below before initiating the data pipeline." 
                       FontSize="16" Foreground="{StaticResource GrayText}" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/> <!-- Main Card -->
                <ColumnDefinition Width="1*"/> <!-- Side Info -->
            </Grid.ColumnDefinitions>

            <!-- Execution Summary Card -->
            <Border Grid.Column="0" Background="{StaticResource BaseWhite}" CornerRadius="16" Padding="32" 
                    BorderBrush="#E2E8F0" BorderThickness="1.5"
                    Effect="{StaticResource CardShadow}"
                    VerticalAlignment="Stretch" Margin="0,0,24,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title/Back -->
                        <RowDefinition Height="*"/>    <!-- Scrollable Content -->
                        <RowDefinition Height="Auto"/> <!-- Action Panel -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <Button Content="← Back" Click="Back_Click" 
                                Style="{StaticResource PrimaryButtonStyle}" 
                                Height="36" FontSize="13" Margin="0,0,16,0" Padding="16,0"
                                ui:ControlHelper.CornerRadius="18"/>
                                
                        <TextBlock Grid.Column="1" Text="Synchronization Manifest" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTeal}" VerticalAlignment="Center" />
                    </Grid>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,24">
                        <StackPanel>
                            <Expander Header="Sync Logs" IsExpanded="False" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" ui:ControlHelper.CornerRadius="10">
                                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="10">
                                    <TextBlock Text="{Binding Summary}" FontSize="14" Foreground="{StaticResource CharcoalText}" 
                                               TextWrapping="Wrap" LineHeight="28" FontFamily="Consolas" Opacity="0.9"/>
                                </ScrollViewer>
                            </Expander>

                            <!-- Sync Progress Panel -->
                            <StackPanel x:Name="SyncProgressPanel" Visibility="Collapsed" Margin="0,24,0,0">
                                <Separator Background="#E2E8F0" Margin="0,0,0,24"/>

                                <Border Background="#ECFEFF" BorderBrush="#A5F3FC" BorderThickness="1" CornerRadius="12" Padding="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:ProgressRing x:Name="SyncRunRing" IsActive="True" Width="40" Height="40"
                                                         Foreground="{StaticResource PrimaryTeal}" Margin="0,0,16,0"
                                                         VerticalAlignment="Top"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="SyncStatusText" Text="Preparing synchronization..."
                                                       FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTeal}"/>
                                            <TextBlock x:Name="SyncStageDetailText" Text="Waiting for the first live update."
                                                       FontSize="12" Foreground="{StaticResource GrayText}" Margin="0,6,0,0"
                                                       TextWrapping="Wrap"/>

                                            <ProgressBar x:Name="SyncProgressBar" Height="12" Minimum="0" Maximum="100"
                                                         Value="0" Margin="0,14,0,0"
                                                         Foreground="{StaticResource PrimaryTeal}" Background="#DDE7EE" BorderThickness="0"
                                                         ui:ControlHelper.CornerRadius="6"/>

                                            <!-- Live Controls -->
                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                <Button x:Name="PauseButton" Content="Pause" Width="90" Click="PauseButton_Click" Height="30" FontSize="12" Background="#E2E8F0" BorderThickness="0"/>
                                                <Button x:Name="CooldownButton" Content="Cooldown" Margin="10,0,0,0" Width="110" Click="ForceCooldown_Click" Height="30" FontSize="12" Background="#FEE2E2" Foreground="#DC2626" BorderBrush="#FECACA"/>
                                            </StackPanel>

                                            <DockPanel Margin="0,10,0,0">
                                                <TextBlock x:Name="SyncProgressCaptionText" Text="Sync engine idle"
                                                           FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                                <TextBlock x:Name="SyncCheckpointText" Text="Next checkpoint at 100 synced records"
                                                           DockPanel.Dock="Right" FontSize="12" Foreground="{StaticResource GrayText}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <UniformGrid Columns="4" Margin="0,16,0,0">
                                    <Border Background="{StaticResource BaseWhite}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="Synced Records" FontSize="11" Foreground="{StaticResource GrayText}"/>
                                            <TextBlock x:Name="SyncedRecordsText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource CharcoalText}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource BaseWhite}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="Voucher Rate" FontSize="11" Foreground="{StaticResource GrayText}"/>
                                            <TextBlock x:Name="VoucherRateText" Text="0 /sec" FontSize="20" FontWeight="Bold" Foreground="{StaticResource CharcoalText}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource BaseWhite}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="Memory" FontSize="11" Foreground="{StaticResource GrayText}"/>
                                            <TextBlock x:Name="MemoryUsageText" Text="0 MB" FontSize="20" FontWeight="Bold" Foreground="{StaticResource CharcoalText}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource BaseWhite}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="Batch Snapshot" FontSize="11" Foreground="{StaticResource GrayText}"/>
                                            <TextBlock x:Name="BatchSnapshotText" Text="Waiting for the first insert batch"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"
                                                       Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Background="{StaticResource BaseWhite}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,16,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock Text="Recent Sync Activity" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                            <Border x:Name="RunStateBadge" DockPanel.Dock="Right" Background="#DCFCE7" CornerRadius="999" Padding="10,4">
                                                <TextBlock x:Name="RunStateBadgeText" Text="Idle" FontSize="11" FontWeight="Bold" Foreground="#166534"/>
                                            </Border>
                                        </DockPanel>

                                        <ScrollViewer Height="170" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="LiveLogList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Timestamp, StringFormat=\{0:HH:mm:ss\}}" FontSize="11" Foreground="#94A3B8" Margin="0,0,10,0"/>
                                                                <Border Grid.Column="1" Background="#E2E8F0" CornerRadius="4" Padding="6,2" Margin="0,0,10,0">
                                                                    <TextBlock Text="{Binding Level}" FontSize="9" FontWeight="Bold" Foreground="#475569"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12" Foreground="{StaticResource CharcoalText}" TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Live telemetry is driven by the real sync monitor and updates as each stage completes."
                                           FontSize="12" Foreground="{StaticResource GrayText}" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" x:Name="ActionPanel" Margin="0,10,0,0">
                        <Separator Margin="0,0,0,16" Background="#E2E8F0"/>
                        
                        <!-- Verified Config Status Wrapper -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="ProtectedDocument" Foreground="#10B981" Margin="0,4,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Verified Configuration: Tally connection established, ready for extraction." 
                                       VerticalAlignment="Center" Foreground="#64748B" FontSize="12" FontStyle="Italic"/>
                        </StackPanel>

                        <!-- Synchronization Action Panel -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Config Section -->
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <ui:SymbolIcon Symbol="Calendar" Foreground="#10B981" Margin="0,0,10,0" />
                                        <TextBlock Text="Sync Range Configuration" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Margin="0,0,24,0">
                                            <TextBlock Text="From Date" FontSize="12" Foreground="#64748B" Margin="0,0,0,6" />
                                            <DatePicker x:Name="SyncFromDatePicker" Width="160" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="To Date" FontSize="12" Foreground="#64748B" Margin="0,0,0,6" />
                                            <DatePicker x:Name="SyncToDatePicker" Width="160" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Safe Sync Options -->
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <StackPanel Margin="0,0,24,0">
                                            <TextBlock Text="Sync Mode" FontSize="12" Foreground="#64748B" Margin="0,0,0,6" />
                                            <ComboBox x:Name="SyncModeCombo" Width="160" SelectedIndex="0" SelectionChanged="SyncModeCombo_SelectionChanged" ui:ControlHelper.CornerRadius="4">
                                                <ComboBoxItem Content="Auto (Adaptive)"/>
                                                <ComboBoxItem Content="Safe (Controlled)"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel x:Name="BatchSizePanel" Visibility="Collapsed">
                                            <TextBlock Text="Batch Size" FontSize="12" Foreground="#64748B" Margin="0,0,0,6" />
                                            <ComboBox x:Name="BatchSizeCombo" Width="100" SelectedIndex="1" ui:ControlHelper.CornerRadius="4">
                                                <ComboBoxItem Content="10"/>
                                                <ComboBoxItem Content="25"/>
                                                <ComboBoxItem Content="50"/>
                                                <ComboBoxItem Content="100"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Action Section -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="24,0,0,0">
                                    <Button x:Name="SyncButton" 
                                            Click="Sync_Click"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Padding="40,16"
                                            Height="56"
                                            Cursor="Hand"
                                            ui:ControlHelper.CornerRadius="28">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Sync" Margin="0,0,14,0" />
                                            <TextBlock Text="Initialize Synchronization" FontSize="19" FontWeight="Bold" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sidebar Info Panel -->
            <StackPanel Grid.Column="1">
                <Border Background="#F0FDFA" CornerRadius="12" Padding="24" Margin="0,0,0,20" BorderBrush="#CCF2F4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💡 Pro Sync Tips" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,12"/>
                        <TextBlock Text="• Ensure Tally ERP 9 is running in the background." FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8" TextWrapping="Wrap" Opacity="0.8"/>
                        <TextBlock Text="• Avoid closing the application during the sync process." FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8" TextWrapping="Wrap" Opacity="0.8"/>
                        <TextBlock Text="• Check the Activity Log if you encounter any warnings." FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,8" TextWrapping="Wrap" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="24" Effect="{StaticResource CardShadow}" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Security &amp; Integrity" FontSize="16" FontWeight="Bold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,12"/>
                        <TextBlock Text="All data is synchronized locally to your warehouse. No financial figures are uploaded to external servers during this process." 
                                   FontSize="12" Foreground="{StaticResource GrayText}" TextWrapping="Wrap" LineHeight="18"/>
                        
                        <Border Background="#F1F5F9" CornerRadius="6" Padding="12" Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Permissions" Foreground="{StaticResource GrayText}" Margin="0,0,10,0"/>
                                <TextBlock Text="Admin Mode Active" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource GrayText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
