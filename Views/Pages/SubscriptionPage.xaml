<Page x:Class="Acczite20.Views.Pages.SubscriptionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Subscription"
      Background="{StaticResource LightTealBg}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24">
        <StackPanel>
            <!-- Back Navigation -->
            <Button Content="← Back" Click="Back_Click" 
                    Style="{StaticResource SidebarButtonStyle}" Foreground="{StaticResource PrimaryTeal}" 
                    HorizontalAlignment="Left" Height="32" Margin="0,0,0,12" FontSize="13"/>

            <TextBlock Text="Subscription Plans"
                       FontSize="24" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,5" />
            <TextBlock Text="Choose the plan that fits your business. Upgrade or downgrade anytime."
                       FontSize="14" Foreground="{StaticResource CharcoalText}" Opacity="0.7" Margin="0,0,0,30" />

            <!-- Current Plan Badge -->
            <Border Background="{StaticResource BaseWhite}" CornerRadius="10" Padding="20" 
                    BorderBrush="{StaticResource GoldMetallic}" BorderThickness="2"
                    Effect="{StaticResource CardShadow}" Margin="0,0,0,24"
                    HorizontalAlignment="Left" Width="600">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Current Plan: " FontSize="15" Foreground="{StaticResource CharcoalText}"/>
                            <TextBlock x:Name="CurrentPlanLabel" Text="Free Trial" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Expires: " FontSize="13" Foreground="#6B7280"/>
                            <TextBlock x:Name="ExpiryLabel" Text="30 days remaining" FontSize="13" FontWeight="SemiBold" Foreground="#F59E0B"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="6" Padding="12,6">
                        <TextBlock Text="✓ Active" FontSize="13" FontWeight="Bold" Foreground="#059669"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Plan Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,24">

                <!-- STARTER -->
                <Border Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="24" 
                        Margin="0,0,16,0" BorderBrush="#E5E7EB" BorderThickness="1"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Starter" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,4"/>
                        <TextBlock Text="For small businesses" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="₹999" FontSize="32" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                            <TextBlock Text="/mo" FontSize="14" Foreground="#6B7280" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                        </StackPanel>

                        <TextBlock Text="✓  1 Organization" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  5 Collections" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  One-Way Sync" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Basic Reports" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✗  Two-Way Sync" FontSize="13" Foreground="#9CA3AF" Margin="0,4"/>
                        <TextBlock Text="✗  Priority Support" FontSize="13" Foreground="#9CA3AF" Margin="0,4"/>

                        <Button Content="Select Starter" Click="SelectStarter_Click" 
                                Style="{StaticResource SidebarButtonStyle}" Foreground="{StaticResource PrimaryTeal}"
                                HorizontalAlignment="Stretch" Margin="0,20,0,0" Height="40"/>
                    </StackPanel>
                </Border>

                <!-- PROFESSIONAL (RECOMMENDED) -->
                <Border Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="24" 
                        Margin="0,0,16,0" BorderBrush="{StaticResource PrimaryTeal}" BorderThickness="2"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Professional" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                            <Border Background="{StaticResource PrimaryTeal}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Right">
                                <TextBlock Text="RECOMMENDED" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="For growing teams" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="₹2,499" FontSize="32" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                            <TextBlock Text="/mo" FontSize="14" Foreground="#6B7280" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                        </StackPanel>

                        <TextBlock Text="✓  5 Organizations" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Unlimited Collections" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Two-Way Sync" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Full Reports + Export" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Email Support" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✗  Dedicated Manager" FontSize="13" Foreground="#9CA3AF" Margin="0,4"/>

                        <Button Content="Upgrade to Pro" Click="SelectPro_Click" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch" Margin="0,20,0,0" Height="40"/>
                    </StackPanel>
                </Border>

                <!-- ENTERPRISE -->
                <Border Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="24" 
                        BorderBrush="{StaticResource GoldMetallic}" BorderThickness="2"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Enterprise" FontSize="20" FontWeight="Bold" Foreground="{StaticResource GoldMetallic}" Margin="0,0,0,4"/>
                        <TextBlock Text="For large organizations" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="₹6,999" FontSize="32" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                            <TextBlock Text="/mo" FontSize="14" Foreground="#6B7280" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                        </StackPanel>

                        <TextBlock Text="✓  Unlimited Organizations" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Unlimited Collections" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Two-Way + Real-Time" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Advanced Analytics" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Priority 24/7 Support" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>
                        <TextBlock Text="✓  Dedicated Account Manager" FontSize="13" Foreground="{StaticResource CharcoalText}" Margin="0,4"/>

                        <Button Content="Contact Sales" Click="SelectEnterprise_Click" 
                                Style="{StaticResource SidebarButtonStyle}" Foreground="{StaticResource GoldMetallic}"
                                HorizontalAlignment="Stretch" Margin="0,20,0,0" Height="40"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- License Key Section -->
            <Border Background="{StaticResource BaseWhite}" CornerRadius="10" Padding="24" 
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Effect="{StaticResource CardShadow}" HorizontalAlignment="Left" Width="600">
                <StackPanel>
                    <TextBlock Text="Activate License Key" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,12"/>
                    <TextBlock Text="Enter your license key received via email after purchase." FontSize="13" Foreground="#6B7280" Margin="0,0,0,12"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LicenseKeyBox" FontSize="14" Padding="8" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="Activate" Click="ActivateLicense_Click"
                                Style="{StaticResource PrimaryButtonStyle}" Width="110" Height="38"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
