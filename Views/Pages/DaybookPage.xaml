<Page x:Class="Acczite20.Views.Pages.DaybookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Daybook" Background="Transparent"
      Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="24" Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Daybook Explorer" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                    <TextBlock Text="Chronological view of all synchronized Tally transactions." 
                               FontSize="14" Foreground="{StaticResource GrayText}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Date Range" FontSize="11" Foreground="{StaticResource GrayText}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <DatePicker x:Name="FromDatePicker" Width="140" ui:ControlHelper.PlaceholderText="From"/>
                            <TextBlock Text="to" VerticalAlignment="Center" Margin="8,0"/>
                            <DatePicker x:Name="ToDatePicker" Width="140" ui:ControlHelper.PlaceholderText="To"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Content="Refresh" Style="{StaticResource PrimaryButtonStyle}" 
                            Height="36" Width="100" VerticalAlignment="Bottom" Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Daybook Grid -->
        <Border Grid.Row="1" Background="{StaticResource BaseWhite}" CornerRadius="12" Effect="{StaticResource CardShadow}" ClipToBounds="True">
            <Grid>
                <DataGrid x:Name="DaybookGrid" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          BorderThickness="0"
                          Background="Transparent"
                          RowHeight="48"
                          SelectionMode="Single">
                    
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="16,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding VoucherDate, StringFormat=\{0:dd-MM-yyyy\}}" Width="100"/>
                        <DataGridTextColumn Header="Vch No" Binding="{Binding VoucherNumber}" Width="80"/>
                        <DataGridTemplateColumn Header="Particulars" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding MainLedgerName}" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Debit" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DebitAmount, StringFormat=\{0:N2\}}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               FontWeight="Bold" Foreground="#1E40AF"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Credit" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CreditAmount, StringFormat=\{0:N2\}}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               FontWeight="Bold" Foreground="#DC2626"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyStatePanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="48" Foreground="{StaticResource GrayText}" Opacity="0.3" HorizontalAlignment="Center"/>
                    <TextBlock Text="No transactions found for this period."
                               FontSize="16" Foreground="{StaticResource GrayText}" Margin="0,16,0,0"/>
                    <TextBlock Text="Try adjusting the filters or run a synchronization."
                               FontSize="12" Foreground="{StaticResource GrayText}" Opacity="0.7" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Loading State -->
                <ui:ProgressRing x:Name="LoadingRing" IsActive="False" Visibility="Collapsed" Width="48" Height="48" Foreground="{StaticResource PrimaryTeal}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
