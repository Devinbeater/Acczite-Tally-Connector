<Page x:Class="Acczite20.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Acczite20.ViewModels"
      mc:Ignorable="d"
      Title="ProfilePage">

	<Page.DataContext>
		<vm:ProfileViewModel />
	</Page.DataContext>

	<Grid Margin="30">
		<StackPanel HorizontalAlignment="Left" Width="300">
			<TextBlock FontSize="26" FontWeight="Bold" Text="👤 User Profile" Margin="0,0,0,20"/>

			<TextBlock Text="Username:"/>
			<TextBox Text="{Binding Username}" IsReadOnly="True" Margin="0,5,0,15"/>

			<TextBlock Text="Email:"/>
			<TextBox Text="{Binding Email}" IsReadOnly="True" Margin="0,5,0,15"/>

			<TextBlock Text="First Name:"/>
			<TextBox Text="{Binding FirstName}" Margin="0,5,0,15"/>

			<TextBlock Text="Last Name:"/>
			<TextBox Text="{Binding LastName}" Margin="0,5,0,15"/>

			<Button Content="💾 Save Changes" 
                    Command="{Binding SaveProfileCommand}" 
                    Width="150" 
                    HorizontalAlignment="Left" 
                    Margin="0,10,0,20"/>

			<TextBlock FontWeight="Bold" Foreground="DarkGreen"
                       Text="{Binding LicenseMessage}" 
                       Margin="0,10,0,0"/>
		</StackPanel>
	</Grid>
</Page>
