<Page x:Class="Acczite20.Views.Pages.BalanceSheetPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Balance Sheet"
      Background="{StaticResource LightTealBg}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Balance Sheet" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="As On:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker x:Name="AsOnDatePicker" Width="140" Margin="0,0,10,0"/>
                <Button Content="Refresh" Click="Refresh_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </DockPanel>

        <!-- Balance Sheet Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Liabilities (Left) -->
            <Border Grid.Column="0" Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="20" Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Liabilities" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,15"/>
                    
                    <Grid DockPanel.Dock="Bottom" Margin="0,15,0,0">
                        <TextBlock Text="Total Liabilities" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="TxtTotalLiabilities" Text="₹ 0.00" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16"/>
                    </Grid>

                    <ScrollViewer>
                        <ItemsControl x:Name="LiabilityList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding GroupName}" Margin="0,0,0,5" FontWeight="Medium">
                                        <ItemsControl ItemsSource="{Binding Ledgers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="20,5,10,5">
                                                        <TextBlock Text="{Binding LedgerName}"/>
                                                        <TextBlock Text="{Binding Amount, StringFormat=N2}" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Assets (Right) -->
            <Border Grid.Column="1" Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="20" Margin="10,0,0,0" Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Assets" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,15"/>

                    <Grid DockPanel.Dock="Bottom" Margin="0,15,0,0">
                        <TextBlock Text="Total Assets" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="TxtTotalAssets" Text="₹ 0.00" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16"/>
                    </Grid>

                    <ScrollViewer>
                        <ItemsControl x:Name="AssetList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding GroupName}" Margin="0,0,0,5" FontWeight="Medium">
                                        <ItemsControl ItemsSource="{Binding Ledgers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="20,5,10,5">
                                                        <TextBlock Text="{Binding LedgerName}"/>
                                                        <TextBlock Text="{Binding Amount, StringFormat=N2}" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Financial Health Status Bar + Diagnostics -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">

            <!-- Status row -->
            <Border x:Name="HealthStatusBar" CornerRadius="8" Padding="16,10">
                <DockPanel>
                    <Ellipse x:Name="HealthDot" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtHealthLabel" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TxtHealthDetail" VerticalAlignment="Center" Opacity="0.8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHealthDiff" FontWeight="Bold" Margin="0,0,16,0"/>
                        <TextBlock x:Name="TxtLastVerified" Opacity="0.6" FontSize="11"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Drill-down diagnostics — shown only when Red/Yellow -->
            <Border x:Name="DiagnosticsPanel" Visibility="Collapsed"
                    Background="#FFF8F8" BorderBrush="#FFCCCC" BorderThickness="1"
                    CornerRadius="8" Padding="16,12" Margin="0,6,0,0">
                <StackPanel>
                    <TextBlock Text="Diagnostics" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" Foreground="#B91C1C"/>

                    <!-- Summary diagnostics -->
                    <ItemsControl x:Name="DiagnosticsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{Binding SeverityColor}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Description}"
                                               TextWrapping="Wrap" FontSize="12" Margin="6,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Top unbalanced vouchers sub-table (hidden when empty) -->
                    <Border x:Name="UnbalancedVouchersPanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Top Unbalanced Vouchers" FontWeight="SemiBold" FontSize="12"
                                       Foreground="#B91C1C" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Voucher No." FontWeight="SemiBold" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Grid.Column="1" Text="Date" FontWeight="SemiBold" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Grid.Column="2" Text="Type" FontWeight="SemiBold" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Grid.Column="3" Text="Imbalance" FontWeight="SemiBold" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Right"/>
                            </Grid>
                            <ItemsControl x:Name="UnbalancedVouchersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding VoucherNumber}" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding VoucherDate, StringFormat=dd-MMM-yy}" FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="{Binding VoucherType}" FontSize="12"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Imbalance, StringFormat=N2}"
                                                       FontSize="12" HorizontalAlignment="Right" Foreground="#DC2626"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Orphan ledgers sub-table (hidden when empty) -->
                    <Border x:Name="OrphanLedgersPanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Unclassified Ledgers (excluded from reports)" FontWeight="SemiBold" FontSize="12"
                                       Foreground="#B45309" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ledger" FontWeight="SemiBold" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Grid.Column="1" Text="Parent Group" FontWeight="SemiBold" FontSize="11" Foreground="#6B7280"/>
                            </Grid>
                            <ItemsControl x:Name="OrphanLedgersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding LedgerName}" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ParentGroup}" FontSize="12" Foreground="#6B7280"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Page>
