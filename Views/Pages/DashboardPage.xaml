<Page x:Class="Acczite20.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Dashboard"
      Background="Transparent">

    <Grid>
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </Grid.Resources>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24">
            <StackPanel>

                <Button Content="&lt; Back"
                        Click="Back_Click"
                        Style="{StaticResource SidebarButtonStyle}"
                        Foreground="{StaticResource PrimaryTeal}"
                        HorizontalAlignment="Left"
                        Height="32"
                        Margin="0,0,0,12"
                        FontSize="13"/>

                <UniformGrid Columns="4" Margin="0,0,0,24">
                    <Border Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,16,0" Effect="{StaticResource CardShadow}" BorderBrush="{StaticResource GoldMetallic}" BorderThickness="0,2,0,0">
                        <StackPanel>
                            <TextBlock Text="Total Vouchers" FontSize="13" Foreground="#6B7280" Margin="0,0,0,8" FontWeight="Medium"/>
                            <TextBlock x:Name="KpiVouchers" Text="-" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,16,0" Effect="{StaticResource CardShadow}" BorderBrush="{StaticResource GoldMetallic}" BorderThickness="0,2,0,0">
                        <StackPanel>
                            <TextBlock Text="Total Ledgers" FontSize="13" Foreground="#6B7280" Margin="0,0,0,8" FontWeight="Medium"/>
                            <TextBlock x:Name="KpiLedgers" Text="-" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,16,0" Effect="{StaticResource CardShadow}" BorderBrush="{StaticResource GoldMetallic}" BorderThickness="0,2,0,0">
                        <StackPanel>
                            <TextBlock Text="Stock Items" FontSize="13" Foreground="#6B7280" Margin="0,0,0,8" FontWeight="Medium"/>
                            <TextBlock x:Name="KpiStockItems" Text="-" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Effect="{StaticResource CardShadow}" BorderBrush="{StaticResource GoldMetallic}" BorderThickness="0,2,0,0">
                        <StackPanel>
                            <TextBlock Text="Today's Sync Count" FontSize="13" Foreground="#6B7280" Margin="0,0,0,8" FontWeight="Medium"/>
                            <TextBlock x:Name="KpiSyncedToday" Text="-" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Ellipse x:Name="SyncDot" Width="10" Height="10" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="SyncStatusLabel" Text="Sync Engine Idle" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Last Sync" FontSize="11" Foreground="#6B7280"/>
                                    <TextBlock x:Name="LastSyncTime" Text="Never" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tally Status" FontSize="11" Foreground="#6B7280"/>
                                    <TextBlock x:Name="TallyStatusLabel" Text="Not Checked" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Connected Company" FontSize="11" Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding ConnectedCompanyName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="Organization" FontSize="11" Foreground="#6B7280"/>
                                    <TextBlock x:Name="OrgLabel" Text="-" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Check Now"
                                Click="CheckNow_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="120"
                                Height="36"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,16,0" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Sync Volume Line Graph" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            <TextBlock Text="Daily voucher sync counts across the last 7 days" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Height="320" Background="#F9FAFB">
                                <lvc:CartesianChart Series="{Binding Series}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Effect="{StaticResource CardShadow}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Realtime Activity" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTeal}"/>
                                    <Border Background="#10B981" Width="8" Height="8" CornerRadius="4" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </StackPanel>
                            </DockPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Monitor.Logs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,6">
                                                <TextBlock Text="{Binding FullLogLine}" Foreground="#4B5563" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,16,0" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Wave Graph" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            <TextBlock Text="Smoothed flow and rolling mean for sync throughput" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Height="280" Background="#F9FAFB">
                                <lvc:CartesianChart Series="{Binding WaveSeries}" XAxes="{Binding WaveXAxes}" YAxes="{Binding WaveYAxes}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Funnel Chart" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            <TextBlock Text="Top inventory movers shown as a tapered funnel" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>

                            <ItemsControl ItemsSource="{Binding FunnelStages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Stage}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ValueLabel}" FontSize="12" FontWeight="Bold" Foreground="#0F172A"/>
                                            </Grid>

                                            <Border Width="{Binding Width}" Height="36" Background="{Binding Fill}" CornerRadius="18" HorizontalAlignment="Center">
                                                <Grid>
                                                    <TextBlock Text="{Binding Caption}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,16,0" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Pie Chart" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            <TextBlock Text="GST distribution by active tax type" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Height="280" Background="#F9FAFB">
                                <lvc:PieChart Series="{Binding GstSeries}" LegendPosition="Right" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Graph Chart" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                            <TextBlock Text="Column view of top inventory items by quantity sold" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Height="280" Background="#F9FAFB">
                                <lvc:CartesianChart Series="{Binding InventoryChartSeries}" XAxes="{Binding InventoryChartXAxes}" YAxes="{Binding InventoryChartYAxes}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{StaticResource BaseWhite}" CornerRadius="8" Padding="20" Margin="0,0,0,8" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Gantt Chart" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" Margin="0,0,0,4"/>
                        <TextBlock Text="Estimated sync pipeline timeline across the current 7-day window" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Pipeline Stage" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}" VerticalAlignment="Center"/>

                            <ItemsControl Grid.Column="1" ItemsSource="{Binding TimelineHeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="0,6" Margin="2,0">
                                            <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding TimelineStages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,4,12,0">
                                            <TextBlock Text="{Binding Stage}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource CharcoalText}"/>
                                            <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="#6B7280" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Grid Grid.Column="1" Height="38">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="6" Margin="2"/>
                                            <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="6" Margin="2"/>
                                            <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="6" Margin="2"/>
                                            <Border Grid.Column="3" Background="#F8FAFC" CornerRadius="6" Margin="2"/>
                                            <Border Grid.Column="4" Background="#F8FAFC" CornerRadius="6" Margin="2"/>
                                            <Border Grid.Column="5" Background="#F8FAFC" CornerRadius="6" Margin="2"/>
                                            <Border Grid.Column="6" Background="#F8FAFC" CornerRadius="6" Margin="2"/>

                                            <Border Grid.Column="{Binding StartColumn}"
                                                    Grid.ColumnSpan="{Binding Span}"
                                                    Background="{Binding Fill}"
                                                    CornerRadius="10"
                                                    Margin="4,6">
                                                <TextBlock Text="{Binding DurationLabel}" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Background="#CCF3FBFC"
                Visibility="{Binding Monitor.IsSyncing, Converter={StaticResource BoolToVis}}"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsActive="True" Width="60" Height="60" Foreground="{StaticResource PrimaryTeal}"/>
                <TextBlock Text="{Binding Monitor.CurrentStage}"
                           Margin="0,20,0,0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTeal}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Monitor.CurrentStageDetail}"
                           FontSize="13"
                           Opacity="0.7"
                           Foreground="{StaticResource CharcoalText}"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"
                           TextWrapping="Wrap"
                           MaxWidth="360"
                           TextAlignment="Center"/>
                <ProgressBar Width="280"
                             Height="10"
                             Margin="0,18,0,0"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding Monitor.ProgressPercent}"
                             IsIndeterminate="{Binding Monitor.IsProgressIndeterminate}"
                             Foreground="{StaticResource PrimaryTeal}"
                             Background="#CDE5E7"
                             BorderThickness="0"/>
                <UniformGrid Columns="3" Margin="0,16,0,0">
                    <Border Background="#FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Synced" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="{Binding Monitor.TotalRecordsSynced, StringFormat={}{0:N0}}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Rate" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="{Binding Monitor.VouchersPerSecond, StringFormat={}{0:N0} /sec}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" CornerRadius="8" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Memory" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="{Binding Monitor.MemoryUsage}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
                <TextBlock Text="{Binding Monitor.CheckpointStatus}"
                           FontSize="12"
                           Foreground="{StaticResource GrayText}"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"/>

                <!-- Sync Controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                    <Button Content="Pause" Click="PauseSync_Click" Width="80" Margin="0,0,10,0"/>
                    <Button Content="Resume" Click="ResumeSync_Click" Width="80" Margin="0,0,10,0"/>
                    <Button Content="Stop Sync" Click="StopSync_Click" Background="#EF4444" Foreground="White" Width="90"/>
                </StackPanel>

                <!-- Expandable Live Logs -->
                <Expander Header="Live Sync Logs" Width="360" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="160">
                        <ItemsControl ItemsSource="{Binding Monitor.Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,4">
                                        <TextBlock Text="{Binding FullLogLine}" Foreground="#4B5563" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Expander>

            </StackPanel>
        </Border>
    </Grid>
</Page>
