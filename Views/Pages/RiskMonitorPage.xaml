<Page x:Class="Acczite20.Views.Pages.RiskMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Customer Risk Monitor" 
      Background="{StaticResource LightTealBg}">

    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Customer Risk Monitor" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}"/>
                <TextBlock Text="AI-driven analysis of payment delinquency and credit exposure." Foreground="{StaticResource GrayText}"/>
            </StackPanel>

            <!-- Summary Chips -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">
                <Border Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="15" Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="High Risk Debtors" FontSize="12" Opacity="0.6"/>
                        <TextBlock x:Name="TxtHighRiskCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#EF4444"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="15" Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Total Risk Exposure" FontSize="12" Opacity="0.6"/>
                        <TextBlock x:Name="TxtTotalExposure" Text="₹ 0.00" FontSize="24" FontWeight="Bold" Foreground="#881337"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource BaseWhite}" CornerRadius="12" Padding="15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Avg. Collection Delay" FontSize="12" Opacity="0.6"/>
                        <TextBlock x:Name="TxtAvgDelay" Text="0 Days" FontSize="24" FontWeight="Bold" Foreground="#F59E0B"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Risk List -->
            <Border Grid.Row="2" Background="{StaticResource BaseWhite}" CornerRadius="15" Padding="25" Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Delinquency Watchlist" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource CharcoalText}"/>
                    
                    <ItemsControl x:Name="RiskList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="0,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Customer Info -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding CustomerName}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource CharcoalText}"/>
                                            <TextBlock Text="{Binding RiskReason}" FontSize="12" Foreground="{StaticResource GrayText}"/>
                                        </StackPanel>

                                        <!-- Exposure Info -->
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,20,0">
                                            <TextBlock Text="Outstanding" FontSize="11" Opacity="0.6" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding TotalOutstanding, StringFormat='₹ {0:N2}'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <!-- Indicators -->
                                        <ItemsControl Grid.Column="2" ItemsSource="{Binding Indicators}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F9FAFB" CornerRadius="10" Padding="8,2" Margin="0,0,5,0" BorderBrush="#E5E7EB" BorderThickness="1">
                                                        <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="SemiBold"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Risk Badge -->
                                        <Border Grid.Column="3" Padding="8,4" CornerRadius="6" HorizontalAlignment="Right">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RiskLevel}" Value="High">
                                                            <Setter Property="Background" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RiskLevel}" Value="Critical">
                                                            <Setter Property="Background" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding RiskLevel}" Foreground="White" FontWeight="Bold" FontSize="11"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
