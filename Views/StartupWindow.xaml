<Window x:Class="Acczite20.Views.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Acczite Startup"
        Icon="pack://application:,,,/Assets/app.ico"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowState="Normal"
        WindowStartupLocation="CenterScreen"
        Height="800"
        Width="1400"
        MinHeight="720"
        MinWidth="1200"
        Background="{StaticResource LightTealBg}">

    <Window.Resources>
        <LinearGradientBrush x:Key="StartupBackdrop" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E6F4F3" Offset="0"/>
            <GradientStop Color="#D8ECEA" Offset="0.55"/>
            <GradientStop Color="#EEF5F4" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource CharcoalText}"/>
            <Setter Property="BorderBrush" Value="#D7E4E3"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F6FAFA"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryTeal}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTeal}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Background" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="#10000000"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTeal}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Background" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="#E81123"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource StartupBackdrop}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="480" Height="480" Fill="#33FFFFFF" Canvas.Left="-120" Canvas.Top="-90"/>
            <Ellipse Width="360" Height="360" Fill="#20C6A75E" Canvas.Right="140" Canvas.Top="80"/>
            <Ellipse Width="520" Height="520" Fill="#140F766E" Canvas.Right="-140" Canvas.Bottom="-220"/>
        </Canvas>
        
        <Border VerticalAlignment="Top" Height="34" Panel.ZIndex="100" Background="#0CFFFFFF" MouseDown="Window_MouseDown">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnMinimize" 
                        Content="&#xE921;" 
                        Style="{StaticResource WindowControlButtonStyle}" 
                        Click="Minimize_Click"/>
                <Button x:Name="BtnClose" 
                        Content="&#xE8BB;" 
                        Style="{StaticResource CloseWindowButtonStyle}" 
                        Click="Close_Click"/>
            </StackPanel>
        </Border>

        <Border Margin="36"
                Background="#F9FCFB"
                CornerRadius="28"
                BorderBrush="#D9E7E5"
                BorderThickness="1"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="64,56,44,56">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#ECF6F5"
                            BorderBrush="#D3E5E2"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18,10"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Enterprise Data Platform"
                                   Foreground="{StaticResource PrimaryTeal}"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,28,0,0">
                        <Border Width="82" Height="82" CornerRadius="41" Background="White" Margin="0,0,24,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Opacity="0.1" Direction="270" ShadowDepth="2"/>
                            </Border.Effect>
                            <Image Source="pack://application:,,,/Assets/logo.jpg" 
                                   Width="72" 
                                   Height="72" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center">
                                <Image.Clip>
                                    <EllipseGeometry Center="36,36" RadiusX="36" RadiusY="36"/>
                                </Image.Clip>
                            </Image>
                        </Border>
                        
                        <TextBlock Text="ACCZITE"
                                   Foreground="{StaticResource PrimaryTeal}"
                                   FontSize="72"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,18,0,0">
                        <TextBlock Text="Tally sync, database control, and enterprise reporting in one workspace."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource CharcoalText}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   MaxWidth="560"/>
                        <TextBlock Text="Run large-volume sync operations, monitor your environment, and move between licensing and access control without leaving the platform shell."
                                   TextWrapping="Wrap"
                                   Margin="0,16,0,0"
                                   Foreground="{StaticResource CharcoalText}"
                                   FontSize="15"
                                   Opacity="0.72"
                                   LineHeight="24"
                                   MaxWidth="560"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="3"
                                 Columns="3"
                                 Margin="0,40,0,0">
                        <Border Margin="0,0,18,0"
                                Background="White"
                                CornerRadius="20"
                                BorderBrush="#D7E4E2"
                                BorderThickness="1"
                                Padding="22">
                            <StackPanel>
                                <TextBlock Text="Realtime Sync"
                                           Foreground="{StaticResource PrimaryTeal}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Connect Tally workflows to your configured storage layer with one operational shell."
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource CharcoalText}"
                                           Opacity="0.72"
                                           FontSize="13"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,18,0"
                                Background="#F4FAF9"
                                CornerRadius="20"
                                BorderBrush="#D7E4E2"
                                BorderThickness="1"
                                Padding="22">
                            <StackPanel>
                                <TextBlock Text="Database Aware"
                                           Foreground="{StaticResource PrimaryTeal}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Support MongoDB and relational flows without fragmenting the startup and navigation experience."
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource CharcoalText}"
                                           Opacity="0.72"
                                           FontSize="13"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White"
                                CornerRadius="20"
                                BorderBrush="#D7E4E2"
                                BorderThickness="1"
                                Padding="22">
                            <StackPanel>
                                <TextBlock Text="Operational Control"
                                           Foreground="{StaticResource PrimaryTeal}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Start licensing, authentication, and sync execution from a single full-screen launch surface."
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource CharcoalText}"
                                           Opacity="0.72"
                                           FontSize="13"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Image Source="Images/bizunite_logo.png"
                               Height="34"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Powered by Bizunite Tech Ventures Pvt Ltd"
                                       Foreground="{StaticResource CharcoalText}"
                                       FontSize="13"
                                       Opacity="0.78"/>
                            <TextBlock Text="Enterprise Sync Console"
                                       Foreground="{StaticResource GoldMetallic}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Grid.Column="1"
                        Margin="20"
                        Background="White"
                        CornerRadius="24"
                        BorderBrush="{StaticResource GoldMetallic}"
                        BorderThickness="1.5"
                        Padding="40">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Width="72"
                                Height="72"
                                Background="#E7F4F2"
                                CornerRadius="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,32">
                             <Image Source="pack://application:,,,/Assets/logo.jpg" 
                                    Width="50" 
                                    Height="50" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center">
                                 <Image.Clip>
                                     <EllipseGeometry Center="25,25" RadiusX="25" RadiusY="25" />
                                 </Image.Clip>
                             </Image>
                        </Border>

                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Welcome to Acczite"
                                       Foreground="{StaticResource CharcoalText}"
                                       FontSize="34"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Enterprise workspace gateway."
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource CharcoalText}"
                                       Opacity="0.6"
                                       FontSize="15"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,34,0,0">
                            <!-- Login Form -->
                            <TextBlock Text="Email or Phone Number" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox x:Name="LoginIdBox" 
                                     Height="48" 
                                     VerticalContentAlignment="Center" 
                                     Padding="12,0" 
                                     ui:ControlHelper.PlaceholderText="Enter email or phone"
                                     Margin="0,0,0,20"/>

                            <TextBlock Text="Password" Foreground="{StaticResource CharcoalText}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="PasswordBox" 
                                         Height="48" 
                                         VerticalContentAlignment="Center" 
                                         Padding="12,0"
                                         Margin="0,0,0,10"/>
                            
                            <CheckBox Content="Remember my workspace" Foreground="{StaticResource CharcoalText}" Opacity="0.7" Margin="0,10,0,0"/>
                        </StackPanel>

                        <Button Grid.Row="3"
                                x:Name="LoginBtn"
                                Content="LOGIN TO WORKSPACE"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="54"
                                FontSize="16"
                                Margin="0,34,0,0"
                                Click="Login_Click"/>

                        <StackPanel Grid.Row="4" Margin="0,16,0,0">
                            <Button Content="GET A LICENSE"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Click="GetLicense_Click"/>
                            <TextBlock Text="Press ESC or use the top-right button to close."
                                       HorizontalAlignment="Center"
                                       Margin="0,16,0,0"
                                       Foreground="{StaticResource CharcoalText}"
                                       FontSize="12"
                                       Opacity="0.58"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
