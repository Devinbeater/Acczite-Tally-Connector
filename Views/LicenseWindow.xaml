<Window x:Class="Acczite20.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Enter License Key"
        Height="360" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{StaticResource LightTealBg}"
        AllowsTransparency="False">

    <Window.Resources>
        <Style x:Key="WindowActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CharcoalText}"/>
            <Setter Property="Background" Value="#F5FAF9"/>
            <Setter Property="BorderBrush" Value="#D6E4E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryTeal}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryTeal}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background subtle accent -->
        <Border Background="{StaticResource PrimaryTeal}" Height="4" VerticalAlignment="Top"/>

        <!-- Central Card -->
        <Border Margin="30"
                Background="{StaticResource BaseWhite}"
                CornerRadius="12"
                Padding="30"
                Effect="{StaticResource CardShadow}"
                BorderBrush="{StaticResource GoldMetallic}" 
                BorderThickness="0,3,0,0">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="&#8722;"
                            Style="{StaticResource WindowActionButtonStyle}"
                            Margin="0,0,8,0"
                            Click="Minimize_Click"/>
                    <Button Content="X"
                            Style="{StaticResource WindowActionButtonStyle}"
                            Click="CloseChrome_Click"/>
                </StackPanel>
                
                <TextBlock Text="License Activation"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTeal}"
                           Margin="0,0,0,5" />

                <TextBlock Grid.Row="1" 
                           Text="Enter your premium enterprise key to continue:"
                           FontSize="13"
                           Foreground="{StaticResource CharcoalText}"
                           Opacity="0.7"
                           TextWrapping="Wrap"
                           Margin="0,0,0,25" />

                <!-- Textbox wrapped in a custom style/border -->
                <Border Grid.Row="2"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="6"
                        Height="45"
                        Margin="0,0,0,30"
                        VerticalAlignment="Top">
                    <TextBox x:Name="LicenseKeyBox"
                             FontSize="16"
                             Padding="12,0,12,0"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource CharcoalText}"
                             VerticalContentAlignment="Center"
                             HorizontalAlignment="Stretch"
                             />
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" 
                            Width="90" Height="36"
                            Click="Cancel_Click" 
                            Margin="0,0,12,0" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Foreground="{StaticResource CharcoalText}"/>
                            
                    <Button x:Name="VerifyButton" 
                            Content="Verify" 
                            Width="90" Height="36"
                            Click="Verify_Click" 
                            Margin="0,0,12,0"
                            Style="{StaticResource PrimaryButtonStyle}" />
                            
                    <!-- Note: the NextButton is hidden or disabled to start with, per original code -->        
                    <Button x:Name="NextButton" 
                            Content="Next" 
                            Width="90" Height="36"
                            Click="Next_Click" 
                            Style="{StaticResource PrimaryButtonStyle}" 
                            IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
