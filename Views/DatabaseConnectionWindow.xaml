<Window x:Class="Acczite20.Views.DatabaseConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Connection"
        Height="560" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA"
        ResizeMode="CanResize"
        FontFamily="Times New Roman"
        Icon="/Assets/app.ico">

	<Window.Resources>
		<!-- Primary Button Style -->
		<Style TargetType="Button" x:Key="PrimaryButtonStyle">
			<Setter Property="Background" Value="#4CAF50" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Padding" Value="8,4" />
			<Setter Property="BorderBrush" Value="#388E3C" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#45A049"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#3A8B40"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter Property="Background" Value="#A5D6A7"/>
								<Setter Property="Foreground" Value="#eee"/>
								<Setter Property="BorderBrush" Value="#81C784"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<!-- Secondary Button Style -->
		<Style TargetType="Button" x:Key="SecondaryButtonStyle">
			<Setter Property="Background" Value="#e0e0e0" />
			<Setter Property="Foreground" Value="#333" />
			<Setter Property="Padding" Value="8,4" />
			<Setter Property="BorderBrush" Value="#ccc" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#ccc" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#bbb" />
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter Property="Background" Value="#f0f0f0" />
								<Setter Property="Foreground" Value="#999" />
								<Setter Property="BorderBrush" Value="#ddd" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Border CornerRadius="12" BorderBrush="#DDD" BorderThickness="1" Padding="25" Margin="15">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Header -->
			<TextBlock x:Name="DbTypeLabel"
                       Text="Enter MySQL Credentials"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#222"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

			<!-- Scrollable Form Contents -->
			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10,0,10,0">
				<StackPanel VerticalAlignment="Top">

					<TextBlock Text="Server Name:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />
					<Border CornerRadius="6" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,15" Background="White">
						<TextBox x:Name="ServerNameBox" Height="36" Padding="8" FontSize="14" Background="Transparent" BorderThickness="0" />
					</Border>

					<TextBlock Text="Database Name:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />
					<Border CornerRadius="6" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,15" Background="White">
						<TextBox x:Name="DatabaseNameBox" Height="36" Padding="8" FontSize="14" Background="Transparent" BorderThickness="0" />
					</Border>

					<TextBlock Text="Username:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />
					<Border CornerRadius="6" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,15" Background="White">
						<TextBox x:Name="UsernameBox" Height="36" Padding="8" FontSize="14" Background="Transparent" BorderThickness="0" />
					</Border>

					<TextBlock Text="Password:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />

					<Grid Margin="0,0,0,15" Height="36">
						<Border x:Name="PasswordBoxBorder" CornerRadius="6" BorderBrush="#CCC" BorderThickness="1" Background="White">
							<PasswordBox x:Name="PasswordBox"
                                         Padding="8"
                                         FontSize="14"
                                         VerticalAlignment="Stretch"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         Background="Transparent"
                                         BorderThickness="0"/>
						</Border>

						<Border x:Name="PasswordTextBorder" CornerRadius="6" BorderBrush="#CCC" BorderThickness="1" Visibility="Collapsed" Background="White">
							<TextBox x:Name="PasswordTextBox"
                                     Padding="8"
                                     FontSize="14"
                                     VerticalAlignment="Stretch"
                                     TextChanged="PasswordTextBox_TextChanged"
                                     Background="Transparent"
                                     BorderThickness="0"/>
						</Border>

						<ToggleButton x:Name="ShowPasswordToggle"
                                      Content="👁"
                                      Width="32" Height="32"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0"
                                      ToolTip="Show/Hide Password"
                                      Checked="ShowPasswordToggle_Checked"
                                      Unchecked="ShowPasswordToggle_Unchecked"
                                      Background="Transparent"
                                      BorderBrush="Transparent" />
					</Grid>
				</StackPanel>
			</ScrollViewer>

			<!-- Buttons -->
			<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0" >
				<Button Content="Cancel"
                        Width="100" Height="36"
                        Margin="0,0,15,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="Cancel_Click" />
				<Button Content="Connect"
                        Width="100" Height="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Connect_Click" />
			</StackPanel>
		</Grid>
	</Border>
</Window>
