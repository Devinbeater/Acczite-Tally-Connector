<ui:ContentDialog x:Class="Acczite20.Views.TallySyncCompleteDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.modernwpf.com/2019"
                  Title="Sync Complete"
                  PrimaryButtonText="Done"
                  DefaultButton="Primary"
                  Grid.Row="1">
    <ui:ContentDialog.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="360"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{StaticResource PrimaryTeal}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="ui:ControlHelper.CornerRadius" Value="8"/>
        </Style>
    </ui:ContentDialog.Resources>

    <StackPanel Width="400" Margin="0,10,0,0">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
            <Border Background="#DCFCE7" CornerRadius="24" Width="48" Height="48" Margin="0,0,16,0">
                <ui:SymbolIcon Symbol="Accept" Foreground="#166534" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Synchronization Successful" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTeal}"/>
                <TextBlock Text="Your Tally data is now up-to-date." FontSize="13" Foreground="{StaticResource GrayText}"/>
            </StackPanel>
        </StackPanel>

        <Border Background="#F0FDFA" CornerRadius="12" Padding="20" BorderBrush="#CCF2F4" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Total Synced" FontSize="11" Foreground="{StaticResource GrayText}" Opacity="0.8"/>
                    <TextBlock x:Name="RecordsText" Text="0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Processing Rate" FontSize="11" Foreground="{StaticResource GrayText}" Opacity="0.8"/>
                    <TextBlock x:Name="RateText" Text="0 /sec" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Text="Recent activities and error logs (if any) are available in the Sync Monitor page." 
                   FontSize="12" Foreground="{StaticResource GrayText}" Margin="0,20,0,0" TextWrapping="Wrap"/>
    </StackPanel>
</ui:ContentDialog>
