<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>LiveChartsCore</id>
    <version>2.0.0-rc5.4</version>
    <authors>BetoRodriguez</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <description>Simple, flexible, interactive and powerful data visualization for .Net, this is the core package probably you need another package also unless you are building your own backed.</description>
    <repository type="git" url="https://github.com/beto-rodriguez/LiveCharts2" branch="refs/heads/master" commit="1af9df52805dc7baa013970a54db6dac21d1c869" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.2">
        <dependency id="System.Text.Json" version="8.0.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net6.0-windows7.0" />
      <group targetFramework="net6.0-windows10.0.19041" />
      <group targetFramework="net8.0" />
      <group targetFramework="net8.0-android34.0" />
      <group targetFramework="net8.0-ios18.0" />
      <group targetFramework="net8.0-maccatalyst18.0" />
      <group targetFramework="net8.0-windows7.0" />
      <group targetFramework="net8.0-windows10.0.19041" />
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.Text.Json" version="8.0.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="System.Text.Json" version="8.0.5" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>