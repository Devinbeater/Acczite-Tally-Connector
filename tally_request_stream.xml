
<ENVELOPE>
  <HEADER>
    <VERSION>1</VERSION>
    <TALLYREQUEST>Export</TALLYREQUEST>
    <TYPE>Collection</TYPE>
    <ID>AccziteVoucherHeaders</ID>
  </HEADER>
  <BODY>
    <DESC>
        
      <STATICVARIABLES>
        <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
        <SVFROMDATE>20251222</SVFROMDATE><SVTODATE>20260225</SVTODATE>
        <SVCURRENTCOMPANY>Vaibhav</SVCURRENTCOMPANY>
        
        
      </STATICVARIABLES>
        <TDL>
          <TDLMESSAGE>
            
            <COLLECTION NAME="AccziteVoucherHeaders" ISMODIFY="No">
              <TYPE>Voucher</TYPE>
              <FILTER>AccziteDateFilter</FILTER>
              <FETCH>MASTERID</FETCH>
            </COLLECTION>
            
            <SYSTEM TYPE="Formulae" NAME="AccziteDateFilter">
               $IsBetween:$Date:##SVFROMDATE:##SVTODATE
            </SYSTEM>
          </TDLMESSAGE>
        </TDL>
    </DESC>
  </BODY>
</ENVELOPE>